<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- Wavy Spotify ribbon banner bg — shown only when Spotify is selected -->
    <ImageView
        android:id="@+id/spotify_wavy_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.0"
        android:visibility="visible" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Top Action Bar Area -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="80dp">
                
                <androidx.cardview.widget.CardView
                    android:id="@+id/back_btn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/app_card_bg">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_grid"
                        android:rotation="180"
                        app:tint="@color/app_icon_tint" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Widget Setup"
                    android:textColor="@color/app_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />

                <!-- NEW: Settings Icon as requested -->
                <ImageView
                    android:id="@+id/settings_button"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="Settings"
                    app:tint="@color/app_icon_tint"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LINKED ACCOUNTS"
                android:textAllCaps="true"
                android:textColor="@color/app_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="32dp">
                
                <!-- Instagram Circular Button -->
                <LinearLayout
                    android:id="@+id/platform_ig_container"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    
                    <androidx.cardview.widget.CardView
                        android:id="@+id/platform_ig_card"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        <!-- We use an inner LinearLayout for the shape background instead of the card's setCardBackgroundColor -> backgroundResource conflict -->
                        <LinearLayout
                            android:id="@+id/platform_ig_bg"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_instagram"
                                app:tint="#FFFFFF"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/platform_ig_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Instagram"
                        android:textColor="@color/app_text_primary"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"
                        android:visibility="invisible"/>
                </LinearLayout>

                <!-- YouTube Circular Button -->
                <LinearLayout
                    android:id="@+id/platform_yt_container"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    
                    <androidx.cardview.widget.CardView
                        android:id="@+id/platform_yt_card"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        <LinearLayout
                            android:id="@+id/platform_yt_bg"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_youtube"
                                app:tint="#FFFFFF"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/platform_yt_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YouTube"
                        android:textColor="@color/app_text_primary"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"
                        android:visibility="invisible"/>
                </LinearLayout>

                <!-- Spotify Circular Button -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:id="@+id/platform_spotify_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/platform_spotify_card"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardCornerRadius="26dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@android:color/transparent">
                            <LinearLayout
                                android:id="@+id/platform_spotify_bg"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_spotify"
                                    app:tint="#FFFFFF"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:id="@+id/platform_spotify_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spotify"
                            android:textColor="@color/app_text_primary"
                            android:textSize="12sp"
                            android:layout_marginTop="8dp"
                            android:textStyle="bold"
                            android:visibility="invisible"/>
                    </LinearLayout>

                </FrameLayout>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/app_card_bg"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <!-- REMOVED THE REDUNDANT ICON BLOCK AS REQUESTED -->
                    
                    <EditText
                        android:id="@+id/account_id_input"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:hint="Instagram Username"
                        android:textColorHint="@color/app_text_hint"
                        android:textColor="@color/app_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:inputType="textPersonName" />
                        
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- REMOVED SPOTIFY API CREDENTIALS AREA ENTIRELY AS REQUESTED -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WIDGET STYLE"
                android:textAllCaps="true"
                android:textColor="@color/app_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <!-- New Modern Style Selector Row (Segmented Control look) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/app_card_bg"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    android:weightSum="3">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/style_minimal_card"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#333333">
                        <TextView
                            android:id="@+id/style_minimal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Minimal"
                            android:textAlignment="center"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:textColor="@color/app_text_primary"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/style_lines_card"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        <TextView
                            android:id="@+id/style_lines"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Lines"
                            android:textAlignment="center"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:textColor="@color/app_text_secondary"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/style_gradient_card"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        <TextView
                            android:id="@+id/style_gradient"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Gradient"
                            android:textAlignment="center"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:textColor="@color/app_text_secondary"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="20dp"
        android:background="#00000000"> <!-- Subtle transparent fade to hide scroll -->

        <androidx.cardview.widget.CardView
            android:id="@+id/add_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/app_cta_bg"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Update Widget"
                android:textColor="@color/app_cta_text"
                android:textSize="16sp"
                android:textStyle="bold" />
                
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</RelativeLayout>
